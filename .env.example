PORT=8787
IOTA_RPC_URL=https://api.mainnet.iota.cafe
# Recommended for current IOTA mainnet RPC shape (contains result.activeValidators):
IOTA_RPC_METHOD=iotax_getLatestIotaSystemState
IOTA_CHECKPOINT_METHOD=iota_getLatestCheckpointSequenceNumber
CHECKPOINT_HISTORY_SIZE=60
VALIDATORS_REFRESH_MS=5000
CHECKPOINT_REFRESH_MS=200
CORS_ORIGIN=http://localhost:5173
# Optional auth header for private RPC providers:
# IOTA_RPC_AUTH_HEADER=Authorization
# IOTA_RPC_AUTH_TOKEN=Bearer YOUR_SECRET_TOKEN
# In production, RPC auth header and token are required by backend validation.
